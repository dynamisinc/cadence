{
  // ==========================================================================
  // Dynamis Reference App - Tasks
  // ==========================================================================
  "version": "2.0.0",
  "tasks": [
    // ========================================================================
    // Backend Tasks
    // ========================================================================
    {
      "label": "build-api",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/api/Api.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "publish-api",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/src/api/Api.csproj",
        "--configuration",
        "Release",
        "--output",
        "${workspaceFolder}/src/api/bin/publish"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "start-api",
      "type": "shell",
      "command": "func host start",
      "options": {
        "cwd": "${workspaceFolder}/src/api"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Azure Functions.*$",
          "endsPattern": "^.*Host started.*$"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "test-api",
      "command": "dotnet",
      "type": "process",
      "args": [
        "test",
        "${workspaceFolder}/src/api.Tests/Api.Tests.csproj",
        "--logger",
        "console;verbosity=detailed"
      ],
      "problemMatcher": "$msCompile",
      "group": "test"
    },
    {
      "label": "ef-add-migration",
      "command": "dotnet",
      "type": "process",
      "args": [
        "ef",
        "migrations",
        "add",
        "${input:migrationName}",
        "--project",
        "${workspaceFolder}/src/api/Api.csproj"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "ef-update-database",
      "command": "dotnet",
      "type": "process",
      "args": [
        "ef",
        "database",
        "update",
        "--project",
        "${workspaceFolder}/src/api/Api.csproj"
      ],
      "problemMatcher": "$msCompile"
    },

    // ========================================================================
    // Frontend Tasks
    // ========================================================================
    {
      "label": "install-frontend",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}/src/frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "start-frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/src/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*VITE.*$",
          "endsPattern": "^.*ready in.*$"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "build-frontend",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/src/frontend"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "test-frontend",
      "type": "shell",
      "command": "npm run test",
      "options": {
        "cwd": "${workspaceFolder}/src/frontend"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "lint-frontend",
      "type": "shell",
      "command": "npm run lint",
      "options": {
        "cwd": "${workspaceFolder}/src/frontend"
      },
      "problemMatcher": ["$eslint-stylish"]
    },

    // ========================================================================
    // Combined Tasks
    // ========================================================================
    {
      "label": "build-all",
      "dependsOn": ["build-api", "build-frontend"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "test-all",
      "dependsOn": ["test-api", "test-frontend"],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ],
  "inputs": [
    {
      "id": "migrationName",
      "type": "promptString",
      "description": "Enter migration name (e.g., AddNotesTable)"
    }
  ]
}
