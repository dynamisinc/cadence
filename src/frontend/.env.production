# Production environment variables (Azure SWA)
# API URL is empty because SWA proxies /api to the linked Functions app
VITE_API_URL=
VITE_SIGNALR_URL=/api

# PWA register type: 'prompt' for production (show update dialog to users)
# Override with 'autoUpdate' in CI/CD for UAT environments
VITE_PWA_REGISTER_TYPE=prompt
