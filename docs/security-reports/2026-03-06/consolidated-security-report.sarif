      "tool": {
        "driver": {
          "name": "OWASP ZAP",
          "informationUri": "https://www.zaproxy.org/",
          "version": "2.17.0",
          "rules": [
            {
              "id": "zap-10035",
              "name": "Strict-Transport-SecurityHeaderNotSet",
              "shortDescription": {
                "text": "Strict-Transport-Security Header Not Set"
              },
              "fullDescription": {
                "text": "HTTP Strict Transport Security (HSTS) is a web security policy mechanism whereby a web server declares that complying user agents (such as a web browser) are to interact with it using only secure HTTPS connections (i.e. HTTP layered over TLS/SSL). HSTS is an IETF standards track protocol and is specified in RFC 6797."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "confidence": 90.0,
                "zapRiskCode": 1,
                "tags": [
                  "CWE-319"
                ]
              },
              "help": {
                "text": "Ensure that your web server, application server, load balancer, etc. is configured to enforce Strict-Transport-Security.",
                "markdown": "Ensure that your web server, application server, load balancer, etc. is configured to enforce Strict-Transport-Security."
              }
            },
            {
              "id": "zap-10049",
              "name": "Non-StorableContent",
              "shortDescription": {
                "text": "Non-Storable Content"
              },
              "fullDescription": {
                "text": "The response contents are not storable by caching components such as proxy servers. If the response does not contain sensitive, personal or user-specific information, it may benefit from being stored and cached, to improve performance."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "confidence": 60.0,
                "zapRiskCode": 0,
                "tags": [
                  "CWE-524"
                ]
              },
              "help": {
                "text": "The content may be marked as storable by ensuring that the following conditions are satisfied: The request method must be understood by the cache and defined as being cacheable (\"GET\", \"HEAD\", and \"POST\" are currently defined as cacheable) The response status code must be understood by the cache (one of the 1XX, 2XX, 3XX, 4XX, or 5XX response classes are generally understood) The \"no-store\" cache directive must not appear in the request or response header fields For caching by \"shared\" caches such as \"proxy\" caches, the \"private\" response directive must not appear in the response For caching by \"shared\" caches such as \"proxy\" caches, the \"Authorization\" header field must not appear in the request, unless the response explicitly allows it (using one of the \"must-revalidate\", \"public\", or \"s-maxage\" Cache-Control response directives) In addition to the conditions above, at least one of the following conditions must also be satisfied by the response: It must contain an \"Expires\" header field It must contain a \"max-age\" response directive For \"shared\" caches such as \"proxy\" caches, it must contain a \"s-maxage\" response directive It must contain a \"Cache Control Extension\" that allows it to be cached It must have a status code that is defined as cacheable by default (200, 203, 204, 206, 300, 301, 404, 405, 410, 414, 501).",
                "markdown": "The content may be marked as storable by ensuring that the following conditions are satisfied: The request method must be understood by the cache and defined as being cacheable (\"GET\", \"HEAD\", and \"POST\" are currently defined as cacheable) The response status code must be understood by the cache (one of the 1XX, 2XX, 3XX, 4XX, or 5XX response classes are generally understood) The \"no-store\" cache directive must not appear in the request or response header fields For caching by \"shared\" caches such as \"proxy\" caches, the \"private\" response directive must not appear in the response For caching by \"shared\" caches such as \"proxy\" caches, the \"Authorization\" header field must not appear in the request, unless the response explicitly allows it (using one of the \"must-revalidate\", \"public\", or \"s-maxage\" Cache-Control response directives) In addition to the conditions above, at least one of the following conditions must also be satisfied by the response: It must contain an \"Expires\" header field It must contain a \"max-age\" response directive For \"shared\" caches such as \"proxy\" caches, it must contain a \"s-maxage\" response directive It must contain a \"Cache Control Extension\" that allows it to be cached It must have a status code that is defined as cacheable by default (200, 203, 204, 206, 300, 301, 404, 405, 410, 414, 501)."
              }
            },
            {
              "id": "zap-90005",
              "name": "Sec-Fetch-DestHeaderisMissing",
              "shortDescription": {
                "text": "Sec-Fetch-Dest Header is Missing"
              },
              "fullDescription": {
                "text": "Specifies how and where the data would be used. For instance, if the value is audio, then the requested resource must be audio data and not any other type of resource."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "confidence": 90.0,
                "zapRiskCode": 0,
                "tags": [
                  "CWE-352"
                ]
              },
              "help": {
                "text": "Ensure that Sec-Fetch-Dest header is included in request headers.",
                "markdown": "Ensure that Sec-Fetch-Dest header is included in request headers."
              }
            }
          ]
        }
      },
