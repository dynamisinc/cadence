      "tool": {
        "driver": {
          "name": "OWASP ZAP",
          "informationUri": "https://www.zaproxy.org/",
          "version": "2.17.0",
          "rules": [
            {
              "id": "zap-10035",
              "name": "Strict-Transport-SecurityHeaderNotSet",
              "shortDescription": {
                "text": "Strict-Transport-Security Header Not Set"
              },
              "fullDescription": {
                "text": "HTTP Strict Transport Security (HSTS) is a web security policy mechanism whereby a web server declares that complying user agents (such as a web browser) are to interact with it using only secure HTTPS connections (i.e. HTTP layered over TLS/SSL). HSTS is an IETF standards track protocol and is specified in RFC 6797."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "confidence": 90.0,
                "zapRiskCode": 1,
                "tags": [
                  "CWE-319"
                ]
              },
              "help": {
                "text": "Ensure that your web server, application server, load balancer, etc. is configured to enforce Strict-Transport-Security.",
                "markdown": "Ensure that your web server, application server, load balancer, etc. is configured to enforce Strict-Transport-Security."
              }
            },
            {
              "id": "zap-90005",
              "name": "Sec-Fetch-DestHeaderisMissing",
              "shortDescription": {
                "text": "Sec-Fetch-Dest Header is Missing"
              },
              "fullDescription": {
                "text": "Specifies how and where the data would be used. For instance, if the value is audio, then the requested resource must be audio data and not any other type of resource."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "confidence": 90.0,
                "zapRiskCode": 0,
                "tags": [
                  "CWE-352"
                ]
              },
              "help": {
                "text": "Ensure that Sec-Fetch-Dest header is included in request headers.",
                "markdown": "Ensure that Sec-Fetch-Dest header is included in request headers."
              }
            },
            {
              "id": "zap-10049",
              "name": "StorableandCacheableContent",
              "shortDescription": {
                "text": "Storable and Cacheable Content"
              },
              "fullDescription": {
                "text": "The response contents are storable by caching components such as proxy servers, and may be retrieved directly from the cache, rather than from the origin server by the caching servers, in response to similar requests from other users. If the response data is sensitive, personal or user-specific, this may result in sensitive information being leaked. In some cases, this may even result in a user gaining complete control of the session of another user, depending on the configuration of the caching components in use in their environment. This is primarily an issue where \"shared\" caching servers such as \"proxy\" caches are configured on the local network. This configuration is typically found in corporate or educational environments, for instance."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "confidence": 60.0,
                "zapRiskCode": 0,
                "tags": [
                  "CWE-524"
                ]
              },
              "help": {
                "text": "Validate that the response does not contain sensitive, personal or user-specific information. If it does, consider the use of the following HTTP response headers, to limit, or prevent the content being stored and retrieved from the cache by another user: Cache-Control: no-cache, no-store, must-revalidate, private Pragma: no-cache Expires: 0 This configuration directs both HTTP 1.0 and HTTP 1.1 compliant caching servers to not store the response, and to not retrieve the response (without validation) from the cache, in response to a similar request.",
                "markdown": "Validate that the response does not contain sensitive, personal or user-specific information. If it does, consider the use of the following HTTP response headers, to limit, or prevent the content being stored and retrieved from the cache by another user: Cache-Control: no-cache, no-store, must-revalidate, private Pragma: no-cache Expires: 0 This configuration directs both HTTP 1.0 and HTTP 1.1 compliant caching servers to not store the response, and to not retrieve the response (without validation) from the cache, in response to a similar request."
              }
            }
          ]
        }
      },
